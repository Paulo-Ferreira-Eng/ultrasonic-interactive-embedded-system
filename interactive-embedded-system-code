const unsigned char* const booFrames[] PROGMEM = {
  frame1, frame2, frame3, frame4, frame5, frame6
};

int totalFrames = 6;
int currentFrame = 0;
unsigned long lastFrameTime = 0;
const int frameInterval = 150;

void setup() {
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("Erro ao iniciar o display"));
    while (true);
  }

  display.clearDisplay();
  display.display();
}

void loop() {
  float distancia = medirDistancia();

  if (distancia > 0 && distancia < DISTANCIA_ALERTA_CM) {
    const unsigned char* scareFrame;
    if (currentFrame < 3) {
      scareFrame = booScaredRight;
    } else {
      scareFrame = booScaredLeft;
    }

    display.clearDisplay();
    display.drawBitmap(0, 0, scareFrame, SCREEN_WIDTH, SCREEN_HEIGHT, WHITE);
    display.display();
    delay(2000);
  } else {
    unsigned long now = millis();
    if (now - lastFrameTime > frameInterval) {
      lastFrameTime = now;

      display.clearDisplay();
      const unsigned char* img;
      img = (const unsigned char*)pgm_read_ptr(&(booFrames[currentFrame]));
      display.drawBitmap(0, 0, img, SCREEN_WIDTH, SCREEN_HEIGHT, WHITE);
      display.display();

      currentFrame = (currentFrame + 1) % totalFrames;
    }
  }
}

// Função para medir distância do sensor
float medirDistancia() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  long duracao = pulseIn(ECHO_PIN, HIGH, 25000); // timeout: 25ms
  if (duracao == 0) return -1; // nada detectado

  float distancia = duracao * 0.0343 / 2.0;
  return distancia;
}
